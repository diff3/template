{
  "shared": {
    "buffer_size": 4096,
    "write_to_log": true,
    "log_file": "proxy.log",
    "listen_host": "0.0.0.0",
    "telnet": {
      "host": "127.0.0.1",
      "port": 1337,
      "auth": {
        "enabled": false,
        "username": "admin",
        "password": "changeme",
        "max_attempts": 3
      }
    },
    "proxy": {
      "adapters": {
        "opcode_parser": true,
        "decode": false,
        "logging": true
      },
      "logging": {
        "mode": "opcode",
        "raw_format": "hex",
        "show_opcode": true,
        "show_decoded": false,
        "show_raw": false,
        "show_raw_if_undecoded": true,
        "max_raw_bytes": 256
      },
      "filter": {
        "whitelist": [],
        "blacklist": []
      },
      "capture": {
        "dump": false,
        "focus": []
      },
      "phases": {
        "auth": {},
        "world": {
          "mode": "srp6"
        }
      },
      "routes": {}
    }
  },
  "states": {
