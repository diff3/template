{
  "shared": {
    "buffer_size": 4096,
    "write_to_log": true,
    "log_file": "proxy.log",
    "listen_host": "0.0.0.0",
    "proxy": {
      "adapters": {
        "opcode_parser": true,
        "decode": false,
        "logging": true
      },
      "logging": {
        "mode": "opcode",
        "raw_format": "hex",
        "show_opcode": true,
        "show_decoded": false,
        "show_raw": false,
        "show_raw_if_undecoded": true,
        "max_raw_bytes": 256
      },
      "filter": {
        "whitelist": [],
        "blacklist": []
      },
      "capture": {
        "dump": false,
        "focus": []
      },
      "phases": {
        "auth": {},
        "world": {}
      },
      "routes": {}
    }
  },
  "states": {
    "default": {
      "enable_log": true,
      "enable_view": true,
      "enable_decode": true,
      "routes": {
        "auth": {
          "listen": 3724,
          "forward": {
            "host": "127.0.0.1",
            "port": 3720
          }
        },
        "world": {
          "listen": 8085,
          "forward": {
            "host": "127.0.0.1",
            "port": 8086
          }
        }
      }
    },
    "skyfire": {
      "routes": {
        "auth": {
          "forward": {
            "host": "192.168.11.30"
          }
        },
        "world": {
          "forward": {
            "host": "192.168.11.30",
            "port": 8086
          }
        }
      }
    }
  }
}
